    pause: jest.fn(),
    resume: jest.fn(),
    restart: jest.fn(),
    quit: jest.fn(),
  } as unknown as GameController;
  return { controller, step, live };
}

const advance = (ms: number) =>
  act(() => {
    jest.advanceTimersByTime(ms);
  });

beforeEach(() => {
  jest.useFakeTimers();
});
afterEach(() => {
  jest.clearAllTimers();
  jest.useRealTimers();
